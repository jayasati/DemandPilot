# Copy to .env and fill in. Never commit .env (gitignored).
#
# Kaggle API credentials — required only to download the M5 dataset
# (https://www.kaggle.com/competitions/m5-forecasting-accuracy).
# Alternative: place kaggle.json in %USERPROFILE%\.kaggle\ (Windows) or ~/.kaggle/.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Override the project root used to resolve relative paths in configs/app.yaml
# (defaults to the current working directory).
# DEMANDPILOT_ROOT=
